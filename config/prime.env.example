# Copy this file to config/prime.env and fill in your Prime Intellect pod details.
# This repo intentionally does not store real API keys, SSH private keys, pod IPs, or tokens.

# -----------------------------------------------------------------------------
# Prime Intellect connection (recommended)
# -----------------------------------------------------------------------------
#
# Prefer setting PRIME_POD_ID and letting scripts resolve SSH host/user/port via:
#   prime pods status <POD_ID> -o json
#
# Get POD_ID from:
#   prime pods list
#
PRIME_POD_ID=""

# -----------------------------------------------------------------------------
# SSH (local machine)
# -----------------------------------------------------------------------------
# Private key used for SSH/scp into pods. This should match `prime config view`
# under SSH Key Path (or be the same key you configured in Prime dashboard/profile).
PRIME_SSH_KEY_PATH="$HOME/.ssh/id_rsa"

# Optional: if you want to bypass `prime pods status` resolution, set these:
# PRIME_SSH_USER="root"
# PRIME_SSH_HOST="0.0.0.0"
# PRIME_SSH_PORT="22"

# Optional hardening (OpenSSH >= 7.6 supports "accept-new")
PRIME_STRICT_HOST_KEY_CHECKING="accept-new"

# Remote directory where scripts will copy/run files.
# Tip: keep this under your home directory on the pod.
PRIME_REMOTE_WORKDIR="~/neurodiffusion"

# -----------------------------------------------------------------------------
# ImageDiffusion streaming ports
# -----------------------------------------------------------------------------
IMAGE_REMOTE_PORT="8000"
IMAGE_LOCAL_PORT="8888"

# -----------------------------------------------------------------------------
# Optional: Jupyter port-forward helper (ImageDiffusion/jupyter_tunnel.sh)
# -----------------------------------------------------------------------------
JUPYTER_REMOTE_PORT="8080"
JUPYTER_LOCAL_PORT="9999"
# JUPYTER_TOKEN=""

# -----------------------------------------------------------------------------
# Optional: Hugging Face token (do NOT store here; set in your shell instead)
# -----------------------------------------------------------------------------
# export HUGGING_FACE_HUB_TOKEN="hf_..."
