# Copy this file to config/vast.env and fill in local Vast.ai run settings.
# Do not commit config/vast.env.

# -----------------------------------------------------------------------------
# Vast.ai CLI / instance
# -----------------------------------------------------------------------------
#
# Authenticate outside the repo:
#   vastai set api-key <KEY>
#   vastai show user --raw
#
VAST_INSTANCE_ID=""
VAST_OFFER_ID=""

# Dedicated automation key for Vast instances.
# Recommended:
#   ssh-keygen -t rsa -b 4096 -N '' -f ~/.ssh/vast_neurodiffusion_rsa -C 'vast-neurodiffusion-rsa'
#   vastai create ssh-key "$(tr -d '\n' < ~/.ssh/vast_neurodiffusion_rsa.pub)"
VAST_SSH_KEY_PATH="$HOME/.ssh/vast_neurodiffusion_rsa"
VAST_SSH_USER="root"

# Optional manual override if `vastai show instances --raw` cannot expose SSH metadata.
# VAST_SSH_HOST=""
# VAST_SSH_PORT=""

# Instance creation defaults.
VAST_IMAGE="pytorch/pytorch:2.7.1-cuda12.8-cudnn9-devel"
VAST_DISK_GB="200"
VAST_LABEL="neurodiffusion_vast"
VAST_ENV="-p 8000:8000"
VAST_ONSTART_CMD="touch ~/.no_auto_tmux; env >> /etc/environment"

# Vast SSH endpoints can be recycled.
VAST_STRICT_HOST_KEY_CHECKING="accept-new"
VAST_USER_KNOWN_HOSTS_FILE="$HOME/.ssh/known_hosts"
VAST_GLOBAL_KNOWN_HOSTS_FILE="/etc/ssh/ssh_known_hosts"

# -----------------------------------------------------------------------------
# Video runtime selector
# -----------------------------------------------------------------------------
VIDEO_MODEL="magi"      # magi|krea
ATTN_BACKEND="auto"     # auto|sage|flash|sdpa

# -----------------------------------------------------------------------------
# Cloudflare R2 persistence
# -----------------------------------------------------------------------------
# Source this outside git before publish/restore operations:
#   source /Users/xenochain/agents/secrets/r2_full_access.env
