# Copy this file to config/vast.env and fill in your instance details.
# This repo intentionally does not store real IPs, ports, or tokens.

# SSH connection to your Vast.ai instance
VAST_SSH_HOST="0.0.0.0"
VAST_SSH_PORT="22"
VAST_SSH_USER="root"
VAST_SSH_KEY_PATH="$HOME/.ssh/id_rsa"

# Optional hardening (OpenSSH >= 7.6 supports "accept-new")
# VAST_STRICT_HOST_KEY_CHECKING="accept-new"
VAST_STRICT_HOST_KEY_CHECKING="no"

# Remote working directory used by scripts (ImageDiffusion uses /workspace by default)
VAST_REMOTE_WORKDIR="/workspace"

# ImageDiffusion streaming ports
IMAGE_REMOTE_PORT="8000"
IMAGE_LOCAL_PORT="8888"

# Optional Jupyter port-forward helper (only used by ImageDiffusion/jupyter_tunnel.sh)
JUPYTER_REMOTE_PORT="8080"
JUPYTER_LOCAL_PORT="9999"
# JUPYTER_TOKEN=""

